POSTGRES_DB=raceframe
POSTGRES_USER=raceframe_admin
POSTGRES_PASSWORD=replace_with_at_least_32_random_bytes
# Host connections use SCRAM. Local socket authentication is left at the
# official entrypoint's initialization default so bootstrap scripts can run.
POSTGRES_INITDB_ARGS=--auth-host=scram-sha-256 --data-checksums

RACEFRAME_OWNER_PASSWORD=replace_with_a_different_random_password
RACEFRAME_APP_PASSWORD=replace_with_a_different_random_password
